{
  "name": "influence-game",
  "private": true,
  "description": "Influence: AI agent social-strategy game",
  "version": "0.8.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun run --filter '*' test:mock",
    "test:engine": "cd packages/engine && bun test src/__tests__/game-engine.test.ts",
    "test:engine:full": "cd packages/engine && doppler run -- bun test",
    "simulate": "cd packages/engine && doppler run -- bun run src/simulate.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "check": "bun run typecheck && bun run lint",
    "dev:api": "cd packages/api && bun run dev",
    "dev:web": "cd packages/web && bun run dev"
  },
  "devDependencies": {
    "puppeteer": "^24.40.0"
  }
}
