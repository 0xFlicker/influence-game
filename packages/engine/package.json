{
  "name": "@influence/engine",
  "version": "0.6.1",
  "description": "Influence game engine — core game logic, state machine, agents",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "simulate": "doppler run -- bun run src/simulate.ts",
    "test": "doppler run -- bun test",
    "test:watch": "doppler run -- bun test --watch",
    "test:mock": "bun test src/__tests__/game-engine.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "check": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "openai": "^4.77.0",
    "rxjs": "^7.8.2",
    "xstate": "^5.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "typescript": "^5.8.3"
  }
}
