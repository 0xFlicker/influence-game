{
  "name": "@influence/api",
  "version": "0.8.1",
  "description": "Influence game HTTP API — Bun + Hono server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "DRIZZLE_MIGRATIONS_DIR=./drizzle bun run --watch src/index.ts",
    "start": "DRIZZLE_MIGRATIONS_DIR=./drizzle bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:mock": "bun test src/__tests__/websocket.test.ts src/__tests__/viewer-event-pacer.test.ts src/__tests__/display-name.test.ts",
    "test:db": "DRIZZLE_MIGRATIONS_DIR=./drizzle bun test src/__tests__/",
    "test:e2e": "bun test src/e2e/",
    "lint": "eslint src/",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "DRIZZLE_MIGRATIONS_DIR=./drizzle bun run src/db/migrate.ts",
    "db:seed": "DRIZZLE_MIGRATIONS_DIR=./drizzle bun run src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@influence/engine": "workspace:*",
    "@privy-io/server-auth": "^1.32.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "jose": "^6.2.1",
    "openai": "^4.77.0",
    "postgres": "^3.4.8",
    "viem": "^2.47.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "typescript": "^5.8.3"
  }
}
