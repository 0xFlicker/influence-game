{
  "name": "@influence/api",
  "version": "0.6.1",
  "description": "Influence game HTTP API — Bun + Hono server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:mock": "bun test src/__tests__/",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@influence/engine": "workspace:*",
    "@privy-io/server-auth": "^1.32.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.0",
    "jose": "^6.2.1",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
  }
}
